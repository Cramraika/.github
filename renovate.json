{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":rebaseStalePrs",
    "group:allNonMajor",
    ":enablePreCommit"
  ],
  "timezone": "Asia/Calcutta",
  "schedule": ["before 5am on monday"],
  "labels": ["dependencies", "renovate"],
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "commitMessageLowerCase": "auto",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "branchConcurrentLimit": 10,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "separateMinorPatch": true,
  "separateMultipleMajor": true,
  "automergeStrategy": "squash",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🤖 Renovate Dependency Dashboard",
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"],
    "schedule": [],
    "prPriority": 10,
    "minimumReleaseAge": null
  },
  "osvVulnerabilityAlerts": true,
  "minimumReleaseAge": "3 days",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "branch",
    "schedule": ["before 5am on monday"]
  },
  "packageRules": [
    {
      "description": "Auto-merge patch/pin/digest everywhere (after CI)",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true
    },
    {
      "description": "Auto-merge dev-dependency minor (after CI)",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true
    },
    {
      "description": "Production minor -> PR + review (NO automerge)",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "labels": ["dependencies", "minor-update", "needs-review"]
    },
    {
      "description": "Major -> PR + explicit review, never auto",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "automergeType": "pr",
      "labels": ["major-update", "needs-review"]
    },
    {
      "description": "Group all Docker base-image + compose digest bumps",
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker base images"
    },
    {
      "description": "Group GitHub Actions bumps (every repo has gha)",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Pin GitHub Actions to digests (supply-chain hardening)",
      "matchManagers": ["github-actions"],
      "matchDepTypes": ["action"],
      "pinDigests": true
    }
  ],
  "ignoreDeps": [],
  "ignorePaths": ["**/node_modules/**", "**/.archived/**", "**/vendor/**"]
}
